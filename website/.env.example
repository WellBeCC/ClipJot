# Copy this file to .env and fill in the values before running locally.
# In GitHub Actions, these are set as repository secrets.

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
# Leave empty to disable analytics.
PUBLIC_GA_ID=

# Cloudflare Worker URL for the EmailOctopus subscription proxy
# Deploy subscribe-proxy/ to Cloudflare Workers first, then paste the worker URL here.
# e.g. https://clipjot-subscribe-proxy.<your-account>.workers.dev
PUBLIC_SUBSCRIBE_WORKER_URL=
