---
import DownloadButtons from './react/DownloadButtons';
---

<section class="relative overflow-hidden bg-[var(--background)] py-20 sm:py-28">
  <!-- Subtle background gradient -->
  <div
    class="absolute inset-0 -z-10 opacity-40"
    style="background: radial-gradient(ellipse 80% 50% at 50% -20%, var(--flexoki-blue-100), transparent);"
  ></div>

  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
    <!-- Badge -->
    <div class="mb-6 inline-flex items-center rounded-full border border-[var(--border)] bg-[var(--surface-panel)] px-4 py-1.5 text-sm text-[var(--muted-foreground)]">
      <span class="mr-2 h-2 w-2 rounded-full bg-[var(--feedback-success)]"></span>
      Free · macOS & Windows
    </div>

    <!-- H1 -->
    <h1 class="text-4xl font-bold tracking-tight text-[var(--foreground)] sm:text-5xl lg:text-6xl">
      Edit screenshots straight<br class="hidden sm:inline" /> from your clipboard
    </h1>

    <!-- Subheading -->
    <p class="mt-6 text-xl text-[var(--muted-foreground)] max-w-2xl mx-auto">
      Paste. Annotate. Copy back. Done in seconds.
    </p>

    <!-- Download buttons island -->
    <div class="mt-10">
      <DownloadButtons client:load />
    </div>

    <!-- Mobile note -->
    <p class="mt-3 text-xs text-[var(--muted-foreground)] sm:hidden">
      Desktop app — download on a Mac or Windows PC
    </p>

    <!-- App screenshot placeholder -->
    <div class="mt-16 mx-auto max-w-3xl">
      <div
        class="rounded-xl border border-[var(--border)] bg-[var(--surface-panel)] shadow-lg overflow-hidden"
        style="aspect-ratio: 16/10;"
      >
        <div class="flex h-full items-center justify-center text-[var(--muted-foreground)]">
          <div class="text-center">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="mx-auto mb-3 opacity-30" aria-hidden="true">
              <rect x="4" y="8" width="40" height="32" rx="4" stroke="currentColor" stroke-width="2" fill="none"/>
              <path d="M12 16h8M12 24h24M12 32h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <rect x="28" y="14" width="12" height="8" rx="2" fill="currentColor" opacity="0.3"/>
            </svg>
            <p class="text-sm">App screenshot coming soon</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
