---
import DownloadButtons from './react/DownloadButtons';
---

<section class="relative overflow-hidden bg-[var(--background)] py-20 sm:py-28">
  <!-- Subtle background gradient -->
  <div
    class="absolute inset-0 -z-10 opacity-40"
    style="background: radial-gradient(ellipse 80% 50% at 50% -20%, var(--flexoki-blue-100), transparent);"
  ></div>

  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
    <!-- Badge -->
    <div data-anim="fade-in" class="mb-6 inline-flex items-center rounded-full border border-[var(--border)] bg-[var(--surface-panel)] px-4 py-1.5 text-sm text-[var(--muted-foreground)]">
      <span class="mr-2 h-2 w-2 rounded-full bg-[var(--feedback-success)]"></span>
      Free · macOS & Windows
    </div>

    <!-- H1 -->
    <h1 data-anim="slide-left" data-anim-delay="1" class="text-4xl font-bold tracking-tight text-[var(--foreground)] sm:text-5xl lg:text-6xl">
      Edit screenshots straight<br class="hidden sm:inline" /> from your clipboard
    </h1>

    <!-- Subheading -->
    <p data-anim="fade-up" data-anim-delay="2" class="mt-6 text-xl text-[var(--muted-foreground)] max-w-2xl mx-auto">
      Paste. Annotate. Copy back. Done in seconds.
    </p>

    <!-- Download buttons island -->
    <div data-anim="fade-up" data-anim-delay="3" class="mt-10">
      <DownloadButtons client:load />
    </div>

    <!-- Mobile note -->
    <p class="mt-3 text-xs text-[var(--muted-foreground)] sm:hidden">
      Desktop app — download on a Mac or Windows PC
    </p>

    <!-- App screenshot -->
    <div data-anim="pop-in" data-anim-delay="4" class="mt-16 mx-auto max-w-5xl">
      <img
        src={`${import.meta.env.BASE_URL}app-screenshot.png`}
        alt="ClipJot app — annotating a screenshot with arrows and text"
        class="w-full"
        width="1200"
        height="750"
        loading="eager"
      />
    </div>
  </div>
</section>
