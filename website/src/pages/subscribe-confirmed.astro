---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import DownloadSection from '../components/DownloadSection.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="You're Almost In – ClipJot"
  description="Thank you for subscribing to ClipJot updates. Check your email to confirm your subscription."
>
  <Header />
  <main>
    <section class="py-24 text-center">
      <div class="mx-auto max-w-xl px-4 sm:px-6">
        <div class="mb-6 flex justify-center">
          <span class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-[var(--surface-panel)] text-4xl">
            ✉️
          </span>
        </div>
        <h1 class="text-3xl font-bold tracking-tight text-[var(--foreground)] sm:text-4xl">
          Check your inbox
        </h1>
        <p class="mt-4 text-lg text-[var(--muted-foreground)]">
          Thanks for subscribing! We've sent you a confirmation email — click the link inside to verify your address and you'll be all set.
        </p>
        <p class="mt-3 text-sm text-[var(--muted-foreground)]">
          Didn't get it? Check your spam folder or try subscribing again.
        </p>
        <a
          href={import.meta.env.BASE_URL}
          class="mt-8 inline-flex h-10 items-center justify-center rounded-md border border-[var(--border)] px-6 text-sm font-medium text-[var(--foreground)] hover:bg-[var(--surface-panel)] transition-colors"
        >
          Back to homepage
        </a>
      </div>
    </section>

    <DownloadSection />
  </main>
  <Footer />
</BaseLayout>
