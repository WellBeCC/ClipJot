---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import DownloadSection from '../components/DownloadSection.astro';
import Footer from '../components/Footer.astro';
import SubscribeConfirmedContent from '../components/react/SubscribeConfirmedContent';
---

<BaseLayout
  title="You're Almost In – ClipJot"
  description="Thank you for subscribing to ClipJot updates. Check your email to confirm your subscription."
>
  <Header />
  <main>
    <section class="py-24 text-center">
      <div class="mx-auto max-w-xl px-4 sm:px-6">
        <SubscribeConfirmedContent />
        <a
          href={import.meta.env.BASE_URL}
          class="mt-8 inline-flex h-10 items-center justify-center rounded-md border border-[var(--border)] px-6 text-sm font-medium text-[var(--foreground)] hover:bg-[var(--surface-panel)] transition-colors"
        >
          Back to homepage
        </a>
      </div>
    </section>

    <DownloadSection />
  </main>
  <Footer />
</BaseLayout>
